# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Aria2 Settings
ARIA2_ENABLED=true
ARIA2_PORT=6800
ARIA2_RPC_URL=ws://localhost:6800/jsonrpc
ARIA2_SECRET=

# Ollama Settings (for series selection)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=300
USE_OLLAMA=true

# Download Settings
DEFAULT_DOWNLOAD_FOLDER=./downloads
MAX_CONCURRENT_DOWNLOADS=3

# Scraping Settings
REQUEST_TIMEOUT=10
GOOGLE_SEARCH_ENABLED=true

# Pirate Bay API (Torrent Source)
TORRENT_DOWNLOAD_TIMEOUT=300
