# API Settings
API_HOST=X.X.X.X
API_PORT=XXXX
DEBUG=XXXXX

# Aria2 Settings
ARIA2_ENABLED=XXXX
ARIA2_PORT=XXXX
ARIA2_RPC_URL=XX:XXXXXXXXXXX:XXXXXXXXXXXX
ARIA2_SECRET=

# Ollama Settings (for series selection)
OLLAMA_URL=XXXX:XXXX.XXX.XX.XXX:XXXXX
# OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=XXXXX.X:XX
USE_OLLAMA=XXXX

# Download Settings
DEFAULT_DOWNLOAD_FOLDER=.XXXXXXXXXX
MAX_CONCURRENT_DOWNLOADS=X

# Per-type download roots (optional). If set, these override the default
# destination for movies/series. Leave blank to use `DEFAULT_DOWNLOAD_FOLDER`.
MOVIES_ROOT_FOLDER=
SERIES_ROOT_FOLDER=

# Telegram Bot settings (optional)
# TELEGRAM_BOT_TOKEN: bot token for telegram_bot/bot.py
# API_URL: URL of the Torrent Downloader API (leave blank to use http://localhost:8000)
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
API_URL=

# Scraping Settings
REQUEST_TIMEOUT=XX
GOOGLE_SEARCH_ENABLED=XXXX

# Base URL for Pirate Bay API (Torrent Source)
TORRENT_SITE_URL=XXXXX:XXXXXXXX.XXX
TORRENT_DOWNLOAD_TIMEOUT=XXXX

TVMD_API_KEY=XXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
