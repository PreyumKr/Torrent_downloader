# API Settings
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# Aria2 Settings
ARIA2_ENABLED=true
ARIA2_PORT=6800
ARIA2_RPC_URL=ws://localhost:6800/jsonrpc
ARIA2_SECRET=

# Ollama Settings (for series selection)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
USE_OLLAMA=true

# Download Settings
DEFAULT_DOWNLOAD_FOLDER=./downloads
TEMP_DOWNLOAD_FOLDER=./downloads/temp
MAX_CONCURRENT_DOWNLOADS=3

# Per-type download roots (optional). If set, these override the default
# destination for movies/series. Leave blank to use `DEFAULT_DOWNLOAD_FOLDER`.
MOVIES_ROOT_FOLDER=
SERIES_ROOT_FOLDER=

# Telegram Bot settings
# TELEGRAM_BOT_TOKEN: bot token for telegram_bot/bot.py
# API_URL: URL of the Torrent Downloader API (e.g., http://localhost:8001)
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
API_URL=http://localhost:8001

# Scraping Settings
REQUEST_TIMEOUT=15
GOOGLE_SEARCH_ENABLED=true

# Base URL for Pirate Bay API (Torrent Source)
TORRENT_SITE_URL=https://apibay.org/q.php
TORRENT_DOWNLOAD_TIMEOUT=300

# Metadata API Keys
TVMD_API_KEY=XXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TVMD_API_URL=https://api.tvmd.com/v1
